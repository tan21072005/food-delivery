<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <!-- Tiêu đề -->
    <TextView
        android:id="@+id/tvPasswordTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="@string/auto_ui_thay_oi_mat_khau_wgq8ot"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- Ô nhập mật khẩu cũ (chỉ dùng cho Change Password) -->
    <RelativeLayout
        android:id="@+id/layoutOldPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/s000000sw1cr50bffffff"
        android:visibility="gone">

        <EditText
            android:id="@+id/edOldPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toStartOf="@+id/ivToggleOld"
            android:background="@android:color/transparent"
            android:hint="@string/auto_ui_nhap_mat_khau_hien_tai_125th7"
            android:inputType="textPassword"
            android:maxLength="20"
            android:paddingStart="16dp"
            android:textColor="@color/black"
            android:textColorHint="#AAAAAA"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/ivToggleOld"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_favorite_border"
            android:contentDescription="@string/auto_ui_toggle_old_password_dryiqh" />
    </RelativeLayout>

    <!-- Ô nhập mật khẩu mới -->
    <RelativeLayout
        android:id="@+id/layoutNewPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/s000000sw1cr50bffffff">

        <EditText
            android:id="@+id/edNewPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toStartOf="@+id/ivToggleNew"
            android:background="@android:color/transparent"
            android:hint="@string/auto_ui_nhap_mat_khau_moi_1n4308"
            android:inputType="textPassword"
            android:maxLength="20"
            android:paddingStart="16dp"
            android:textColor="@color/black"
            android:textColorHint="#AAAAAA"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/ivToggleNew"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_eye_off"
            android:contentDescription="@string/auto_ui_toggle_password_1r2m7s" />
    </RelativeLayout>

    <!-- Ô nhập lại mật khẩu -->
    <RelativeLayout
        android:id="@+id/layoutConfirmPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/s000000sw1cr50bffffff">

        <EditText
            android:id="@+id/edConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toStartOf="@+id/ivToggleConfirm"
            android:background="@android:color/transparent"
            android:hint="@string/auto_ui_nhap_lai_mat_khau_moi_1bf0kl"
            android:inputType="textPassword"
            android:maxLength="20"
            android:paddingStart="16dp"
            android:textColor="@color/black"
            android:textColorHint="#AAAAAA"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/ivToggleConfirm"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_eye_off"
            android:contentDescription="@string/auto_ui_toggle_confirm_password_4z8qjk" />
    </RelativeLayout>

    <!-- Ghi chú yêu cầu mật khẩu -->
    <TextView
        android:id="@+id/tvPasswordRules"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/auto_ui_toi_thieu_6_ky_tu_n_chua_chu_cai_va_so_bbttid"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp" />

    <!-- Nút Xác nhận -->
    <Button
        android:id="@+id/btnSubmitPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/btn_pink_rounded"
        android:text="@string/auto_ui_xac_nhan_1tmqpl"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

</LinearLayout>

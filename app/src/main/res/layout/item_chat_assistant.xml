<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingTop="4dp"
    android:paddingEnd="32dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/assistantMessageText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_assistant"
        android:textColor="@color/chat_ink"
        android:textIsSelectable="true"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/assistantMessageTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:contentDescription="@string/chat_message_time"
        android:textColor="@color/chat_muted"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/feedbackPrompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/chat_feedback_prompt"
        android:textColor="@color/chat_muted"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/feedbackActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/feedbackUpButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/chat_feedback_yes"
            android:textColor="@color/chat_ink"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_feedback_up"
            app:iconTint="@color/chat_ink"
            app:strokeColor="@color/chat_composer_stroke" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/feedbackDownButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="@string/chat_feedback_no"
            android:textColor="@color/chat_ink"
            app:cornerRadius="20dp"
            app:icon="@drawable/ic_feedback_down"
            app:iconTint="@color/chat_ink"
            app:strokeColor="@color/chat_composer_stroke" />
    </LinearLayout>

</LinearLayout>

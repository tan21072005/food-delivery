<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:paddingBottom="18dp" android:clickable="true"
    android:focusable="true" android:foreground="?attr/selectableItemBackground">
    <ImageView android:id="@+id/collectionImage" android:layout_width="0dp"
        android:layout_height="132dp" android:scaleType="centerCrop"
        android:background="@drawable/favorite_card_teal" android:clipToOutline="true"
        android:contentDescription="@string/auto_ui_anh_bo_suu_tap_xeyes1"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <ImageButton android:id="@+id/collectionMenu" android:layout_width="48dp" android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/more_vert_24dp"
        android:contentDescription="@string/auto_ui_tuy_chon_bo_suu_tap_1xk7p6" app:layout_constraintTop_toBottomOf="@id/collectionImage"
        app:layout_constraintEnd_toEndOf="parent" />
    <TextView android:id="@+id/collectionName" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_marginTop="10dp"
        android:maxLines="1" android:ellipsize="end" android:textColor="#111314"
        android:textSize="18sp" android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/collectionImage" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/collectionMenu" />
    <TextView android:id="@+id/collectionCount" android:layout_width="0dp"
        android:layout_height="wrap_content" android:layout_marginTop="4dp"
        android:textColor="#92999B" android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/collectionName" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/collectionMenu" />
</androidx.constraintlayout.widget.ConstraintLayout>

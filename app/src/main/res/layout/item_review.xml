<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="14dp"
    android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar"
    android:background="@color/white">

    <!-- Reviewer header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <!-- Avatar circle -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/badge_circle"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvReviewerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <!-- Stars + time -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <LinearLayout
                    android:id="@+id/reviewStarsRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- Stars set programmatically -->
                    <ImageView android:layout_width="13dp" android:layout_height="13dp" android:src="@drawable/ic_star" app:tint="#F5A623"/>
                    <ImageView android:layout_width="13dp" android:layout_height="13dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                    <ImageView android:layout_width="13dp" android:layout_height="13dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                    <ImageView android:layout_width="13dp" android:layout_height="13dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                    <ImageView android:layout_width="13dp" android:layout_height="13dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvReviewTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 ngày trước"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Review text (optional) -->
    <TextView
        android:id="@+id/tvReviewText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#666666"
        android:lineSpacingMultiplier="1.5"
        android:visibility="gone"/>

    <!-- Tag chips (optional) -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupTags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:chipSpacingHorizontal="6dp"
        app:chipSpacingVertical="4dp"
        android:visibility="gone"/>

</LinearLayout>

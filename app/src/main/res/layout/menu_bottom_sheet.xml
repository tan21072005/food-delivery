<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Menu"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCloseMenuSheet"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="✕"
            android:textColor="#111111"
            android:textSize="18sp" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <!-- List of categories (mock) -->
    <!-- Bún -->
    <LinearLayout
        android:id="@+id/rowBun"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bún"
            android:textColor="#333333"
            android:textSize="15sp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15"
            android:textColor="#666666"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="#888888"
            android:textSize="20sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Đồ ăn nhanh -->
    <LinearLayout
        android:id="@+id/rowFastFood"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Đồ ăn nhanh"
            android:textColor="#333333"
            android:textSize="15sp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25"
            android:textColor="#666666"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="#888888"
            android:textSize="20sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Nước -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Nước" android:textColor="#333333" android:textSize="15sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5 ›" android:textColor="#666666" android:textSize="16sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Bánh Mỳ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Bánh Mỳ" android:textColor="#333333" android:textSize="15sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10 ›" android:textColor="#666666" android:textSize="16sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Lẩu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Lẩu" android:textColor="#333333" android:textSize="15sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20 ›" android:textColor="#666666" android:textSize="16sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Tráng miệng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tráng miệng" android:textColor="#333333" android:textSize="15sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12 ›" android:textColor="#666666" android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="@string/auto_ui_menu_59vra"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCloseMenuSheet"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="@string/auto_ui_symbol_7vy"
            android:textColor="#111111"
            android:textSize="18sp" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <!-- List of categories (mock) -->
    <!-- Bún -->
    <LinearLayout
        android:id="@+id/rowBun"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/auto_ui_bun_5zwv"
            android:textColor="#333333"
            android:textSize="15sp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ui_15_6ej"
            android:textColor="#666666"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ui_symbol_6j7"
            android:textColor="#888888"
            android:textSize="20sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Đồ ăn nhanh -->
    <LinearLayout
        android:id="@+id/rowFastFood"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/auto_ui_o_an_nhanh_1w72tu"
            android:textColor="#333333"
            android:textSize="15sp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ui_25_6fe"
            android:textColor="#666666"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ui_symbol_6j7"
            android:textColor="#888888"
            android:textSize="20sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Nước -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/auto_ui_nuoc_5mihd" android:textColor="#333333" android:textSize="15sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_5_5rc8" android:textColor="#666666" android:textSize="16sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Bánh Mỳ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/auto_ui_banh_my_70ow6" android:textColor="#333333" android:textSize="15sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_10_4r18g" android:textColor="#666666" android:textSize="16sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Lẩu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/auto_ui_lau_b93l" android:textColor="#333333" android:textSize="15sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_20_4ro7z" android:textColor="#666666" android:textSize="16sp" />
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

    <!-- Tráng miệng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/auto_ui_trang_mieng_muvuop" android:textColor="#333333" android:textSize="15sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_12_4r2pu" android:textColor="#666666" android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <!-- Tiêu đề -->
    <TextView
        android:id="@+id/tvResetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="Thay đổi mật khẩu"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- Ô nhập mật khẩu mới -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/s000000sw1cr50bffffff">

        <EditText
            android:id="@+id/edNewPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toStartOf="@+id/ivToggleNew"
            android:background="@android:color/transparent"
            android:hint="Nhập mật khẩu mới"
            android:inputType="textPassword"
            android:maxLength="20"
            android:paddingStart="16dp"
            android:textColor="@color/black"
            android:textColorHint="#AAAAAA"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/ivToggleNew"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_favorite_border"
            android:contentDescription="toggle password" />
    </RelativeLayout>

    <!-- Ô nhập lại mật khẩu -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/s000000sw1cr50bffffff">

        <EditText
            android:id="@+id/edConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toStartOf="@+id/ivToggleConfirm"
            android:background="@android:color/transparent"
            android:hint="Nhập lại mật khẩu"
            android:inputType="textPassword"
            android:maxLength="20"
            android:paddingStart="16dp"
            android:textColor="@color/black"
            android:textColorHint="#AAAAAA"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/ivToggleConfirm"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_favorite_border"
            android:contentDescription="toggle confirm password" />
    </RelativeLayout>

    <!-- Ghi chú yêu cầu mật khẩu -->
    <TextView
        android:id="@+id/tvPasswordRules"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="• 8 ký tự ( tối đa 20 ký tự)\n• 1 chữ cái, 1 chữ số, 1 ký tự đặc biệt\n• Mật khẩu mạnh"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp" />

    <!-- Nút Xác nhận -->
    <Button
        android:id="@+id/btnConfirmReset"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/btn_pink_rounded"
        android:text="Xác nhận"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:clickable="true"
    android:focusable="true"
    android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_left"
            android:contentDescription="Quay lại"
            app:tint="#000000" />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Đánh giá"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:gravity="center" />

        <!-- Empty view to balance the Back button for center text alignment -->
        <View
            android:layout_width="24dp"
            android:layout_height="24dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Lời cảm ơn -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cảm ơn bạn đã lựa chọn món tại ứng dụng của chúng tôi! Hy vọng bạn đã có một bữa ăn ngon miệng."
                android:textSize="14sp"
                android:textColor="#666666"
                android:background="#FFFFFF"
                android:padding="16dp" />

            <View android:layout_width="match_parent" android:layout_height="8dp" />

            <!-- Đánh giá Nhà Hàng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đánh giá nhà hàng"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />

                <!-- Rating Bar Nhà hàng -->
                <LinearLayout
                    android:id="@+id/llRestaurantRating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="16dp">
                    <ImageView android:id="@+id/starRes1" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_outline" app:tint="#FFA000"/>
                    <ImageView android:id="@+id/starRes2" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_outline" app:tint="#FFA000"/>
                    <ImageView android:id="@+id/starRes3" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_outline" app:tint="#FFA000"/>
                    <ImageView android:id="@+id/starRes4" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_outline" app:tint="#FFA000"/>
                    <ImageView android:id="@+id/starRes5" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_outline" app:tint="#FFA000"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvResRatingDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Tuyệt vời"
                    android:textSize="14sp"
                    android:textColor="#FFA000"
                    android:visibility="gone" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginTop="16dp" android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đánh giá về món ăn"
                    android:textSize="14sp"
                    android:textColor="#444444"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="false">
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngon xỉu"
                        style="@style/Widget.MaterialComponents.Chip.Filter" />
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sạch sẽ"
                        style="@style/Widget.MaterialComponents.Chip.Filter" />
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đóng gói cẩn thận"
                        style="@style/Widget.MaterialComponents.Chip.Filter" />
                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giao đúng món"
                        style="@style/Widget.MaterialComponents.Chip.Filter" />
                </com.google.android.material.chip.ChipGroup>

                <EditText
                    android:id="@+id/etResReview"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_search_box"
                    android:gravity="top|start"
                    android:hint="Chia sẻ thêm ý kiến của bạn nhé (tùy chọn)"
                    android:padding="12dp"
                    android:textSize="14sp" />

                <!-- Thêm ảnh -->
                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_image_rounded"
                    android:layout_marginTop="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_camera"
                        app:tint="#666666" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Thêm ảnh"
                        android:textSize="12sp"
                        android:textColor="#666666" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginTop="16dp" android:layout_marginBottom="16dp"/>

                <!-- Đánh giá món ăn thumbs up / down -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:id="@+id/imgReviewFood"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/food_bun_thap_cam"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_image_rounded" />
                    
                    <TextView
                        android:id="@+id/tvReviewFoodName"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Bún thập cẩm"
                        android:textSize="14sp"
                        android:textColor="#1A1A1A"
                        android:layout_marginStart="12dp" />

                    <!-- Thumb down -->
                    <ImageView
                        android:id="@+id/ivThumbDown"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_thumb_down"
                        app:tint="#999999"
                        android:layout_marginEnd="16dp" />

                    <!-- Thumb up -->
                    <ImageView
                        android:id="@+id/ivThumbUp"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_thumb_up"
                        app:tint="#1A7A4A" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp" />

            <!-- Đánh giá Tài Xế -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đánh giá tài xế"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#000000" />

                <!-- Rating Bar Tài xế -->
                <LinearLayout
                    android:id="@+id/llDriverRating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="16dp">
                    <ImageView android:id="@+id/starDriver1" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_outline" app:tint="#FFA000"/>
                    <ImageView android:id="@+id/starDriver2" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_outline" app:tint="#FFA000"/>
                    <ImageView android:id="@+id/starDriver3" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_outline" app:tint="#FFA000"/>
                    <ImageView android:id="@+id/starDriver4" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_outline" app:tint="#FFA000"/>
                    <ImageView android:id="@+id/starDriver5" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star_outline" app:tint="#FFA000"/>
                </LinearLayout>

                <EditText
                    android:id="@+id/etDriverReview"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_search_box"
                    android:gravity="top|start"
                    android:hint="Chia sẻ thêm ý kiến của bạn nhé (tùy chọn)"
                    android:padding="12dp"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Submit Button inside ScrollView -->
            <Button
                android:id="@+id/btnSubmitReview"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="24dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:backgroundTint="#FF6D00"
                android:text="Gửi đánh giá"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>

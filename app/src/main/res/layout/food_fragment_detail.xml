<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <!-- Top AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.Design.Light.NoActionBar"
        android:background="@color/white"
        android:elevation="2dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_close">

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ui_chi_tiet_mon_an_1yxrq0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginEnd="16dp"
                android:layout_gravity="center_vertical"/>
                
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_share"
                app:tint="#1A1A1A"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"/>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/appBarLayout"
        android:layout_above="@id/bottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">
            
            <ImageView
                android:id="@+id/imgFood"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:visibility="visible"/>

            <!-- Item name and desc -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvFoodName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_ui_ten_mon_an_1jhvfa"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />
                    
                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_ui_mo_ta_mon_an_rsjrs2"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#EEEEEE" />

            <!-- Option Group 1 (Size) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_ui_chon_size_1ihmjh"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_ui_bat_buoc_1hvd5y"
                        android:textSize="12sp"
                        android:textColor="#1A1A1A"
                        android:background="#F0F0F0"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

                <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">
                    
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_size_vua_iwjbro" android:textSize="15sp" android:textColor="#1A1A1A" android:layout_centerVertical="true"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_alignParentEnd="true" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_0_6js" android:textSize="14sp" android:textColor="#666666" android:layout_marginEnd="8dp"/>
                            <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:buttonTint="#F5A623"/>
                        </LinearLayout>
                    </RelativeLayout>
                    
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />
                    
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_size_lon_iwj3zb" android:textSize="15sp" android:textColor="#1A1A1A" android:layout_centerVertical="true"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_alignParentEnd="true" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_10_000_l0ol7t" android:textSize="14sp" android:textColor="#666666" android:layout_marginEnd="8dp"/>
                            <RadioButton android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="#F5A623"/>
                        </LinearLayout>
                    </RelativeLayout>
                </RadioGroup>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#EEEEEE" />

            <!-- Option Group 2 (Topping) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_ui_them_sot_f62qz8"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_ui_chon_toi_a_2_ega6y1"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">
                    
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_them_2_goi_tuong_chua_ngot_1co7r7" android:textSize="15sp" android:textColor="#1A1A1A" android:layout_centerVertical="true"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_alignParentEnd="true" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_1_000_1jn1mi" android:textSize="14sp" android:textColor="#666666" android:layout_marginEnd="8dp"/>
                            <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="#F5A623"/>
                        </LinearLayout>
                    </RelativeLayout>
                    
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" />
                    
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_them_2_goi_tuong_ca_1wcpsq" android:textSize="15sp" android:textColor="#1A1A1A" android:layout_centerVertical="true"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_alignParentEnd="true" android:gravity="center_vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/auto_ui_1_000_1jn1mi" android:textSize="14sp" android:textColor="#666666" android:layout_marginEnd="8dp"/>
                            <CheckBox android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="#F5A623"/>
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#EEEEEE" />

            <!-- Note section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_ui_ghi_chu_cho_quan_1d8lfa"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="12dp"/>
                    
                <EditText
                    android:id="@+id/edNote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/auto_ui_cho_quan_biet_them_ve_yeu_cau_cua_ban_1r7nrm"
                    android:background="@drawable/bg_rounded_border"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:minHeight="80dp"
                    android:gravity="top|start"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:background="@color/white"
        android:elevation="8dp">

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <!-- Total Price -->
            <TextView
                android:id="@+id/tvTotalPrice"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/auto_ui_145_000_39uh9g"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <!-- Quantity Selector -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btnMinus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_remove"
                    app:tint="#888888"
                    android:background="@drawable/bg_rounded_gray" />

                <TextView
                    android:id="@+id/tvQuantity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_ui_1_7e"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginHorizontal="16dp" />

                <ImageButton
                    android:id="@+id/btnPlus"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_add"
                    app:tint="#1A1A1A"
                    android:background="@drawable/bg_rounded_yellow" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddToCart"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:text="@string/auto_ui_them_vao_gio_1nuw82"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            app:backgroundTint="#FFCA28"
            app:cornerRadius="8dp" />
    </LinearLayout>

</RelativeLayout>

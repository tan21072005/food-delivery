<?xml version="1.0" encoding="utf-8"?>
<!-- Item trong bottom sheet giỏ hàng -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/ivItemImage"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_image_rounded"
        android:scaleType="centerCrop"
        android:src="@drawable/placeholder_food" />

    <!-- Tên món + mô tả -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvItemName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ui_ten_mon_1jizsi"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_menu"
                android:tint="#888888" />

        <TextView
            android:id="@+id/tvItemDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ui_nhieu_bun_khong_thit_yozl3n"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvEditItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/auto_ui_sua_bfwg"
            android:textColor="@color/blue"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvItemPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ui_35_000_1gqp9m"
            android:textColor="#111111"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Điều chỉnh số lượng: [ − ] qty [ + ] -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnDecrease"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="@string/auto_ui_symbol_6wb"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_qty_yellow"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvQty"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/auto_ui_1_7e"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnIncrease"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="@string/auto_ui_symbol_78"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:background="@drawable/btn_qty_yellow"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>

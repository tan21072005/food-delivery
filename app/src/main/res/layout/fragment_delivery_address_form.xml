<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:background="#F8F8F8">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="2dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back">

            <TextView
                android:id="@+id/tvDeliveryAddressFormTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/auto_ui_them_dia_chi_moi_3c33ey"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/etRecipientName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_rounded_white"
                android:hint="@string/auto_ui_ten_nguoi_nhan_nelisb"
                android:inputType="textPersonName"
                android:paddingHorizontal="14dp"
                android:textSize="15sp"/>

            <EditText
                android:id="@+id/etRecipientPhone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_white"
                android:hint="@string/auto_ui_so_dien_thoai_nguoi_nhan_w4gz0j"
                android:inputType="phone"
                android:paddingHorizontal="14dp"
                android:textSize="15sp"/>

            <EditText
                android:id="@+id/etFullAddress"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_white"
                android:gravity="top"
                android:hint="@string/auto_ui_dia_chi_bat_buoc_b7mspl"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:padding="14dp"
                android:textSize="15sp"/>

            <EditText
                android:id="@+id/etBuildingFloor"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_white"
                android:hint="@string/auto_ui_toa_nha_tang_tuy_chon_e4vqzo"
                android:paddingHorizontal="14dp"
                android:textSize="15sp"/>

            <EditText
                android:id="@+id/etGate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_white"
                android:hint="@string/auto_ui_cong_vao_tuy_chon_12dqnd"
                android:paddingHorizontal="14dp"
                android:textSize="15sp"/>

            <RadioGroup
                android:id="@+id/rgAddressType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbHome"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/auto_ui_nha_65b4"/>

                <RadioButton
                    android:id="@+id/rbWork"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/auto_ui_cong_ty_vxdc2h"/>

                <RadioButton
                    android:id="@+id/rbOther"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/auto_ui_khac_58nom"/>
            </RadioGroup>

            <EditText
                android:id="@+id/etCustomName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_white"
                android:hint="@string/auto_ui_ten_dia_chi_115v79"
                android:paddingHorizontal="14dp"
                android:textSize="15sp"
                android:visibility="gone"/>

            <EditText
                android:id="@+id/etDriverNote"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_rounded_white"
                android:gravity="top"
                android:hint="@string/auto_ui_ghi_chu_cho_tai_xe_tuy_chon_17ok0g"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:padding="14dp"
                android:textSize="15sp"/>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveAddress"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:enabled="false"
            android:text="@string/auto_ui_luu_dia_chi_dnytet"
            android:textColor="#1A1A1A"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#FFCA28"
            app:cornerRadius="8dp"/>
    </LinearLayout>
</LinearLayout>

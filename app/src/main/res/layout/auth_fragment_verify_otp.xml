<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <!-- Tiêu đề -->
    <TextView
        android:id="@+id/tvOtpTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="@string/auto_ui_nhap_ma_gom_6_so_22p3at"
        android:textColor="@color/black"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- Mô tả email -->
    <TextView
        android:id="@+id/tvEmailDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/auto_ui_kiem_tra_hoc_gmail_com_e_lay_ma_xac_minh_s333sp"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:lineSpacingExtra="2dp" />

    <!-- Thay đổi email -->
    <TextView
        android:id="@+id/tvChangeEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/auto_ui_thay_oi_email_4cafrn"
        android:textColor="@color/blue"
        android:textSize="14sp" />

    <!-- Ô nhập OTP -->
    <EditText
        android:id="@+id/edOtp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:hint="@string/auto_ui_nhap_ma_gom_6_chu_so_j7bfel"
        android:inputType="numberPassword"
        android:maxLength="6"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:textColorHint="#AAAAAA"
        android:background="@drawable/s000000sw1cr50bffffff" />

    <!-- Gửi lại mã -->
    <TextView
        android:id="@+id/tvResendCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/auto_ui_gui_lai_ma_1fy3fe"
        android:textColor="@color/blue"
        android:textSize="14sp" />

    <!-- Nút Gửi -->
    <Button
        android:id="@+id/btnSubmitOtp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/cr50b131313"
        android:text="@string/auto_ui_gui_b70c"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Ghi chú thư rác -->
    <TextView
        android:id="@+id/tvSpamNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/auto_ui_neu_ban_khong_thay_email_trong_hop_thu_en__1ep2k3"
        android:textColor="@color/black"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp" />

    <!-- Không thể truy cập email -->
    <TextView
        android:id="@+id/tvCantAccessEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/auto_ui_khong_the_truy_cap_uoc_email_nay_15rd0v"
        android:textColor="@color/blue"
        android:textSize="14sp" />

</LinearLayout>
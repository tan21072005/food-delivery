<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar"
    android:background="@color/white">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="2dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="Đánh giá của quán"
            app:titleTextColor="#1A1A1A"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Overall Rating Summary -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="18dp"
        android:gravity="center_vertical"
        android:background="#F8F8F8">

        <!-- Left: big number + stars + count -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="20dp">

            <TextView
                android:id="@+id/tvOverallRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ui_4_5_5klw"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <ImageView android:layout_width="17dp" android:layout_height="17dp" android:src="@drawable/ic_star" app:tint="#F5A623"/>
                <ImageView android:layout_width="17dp" android:layout_height="17dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                <ImageView android:layout_width="17dp" android:layout_height="17dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                <ImageView android:layout_width="17dp" android:layout_height="17dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                <ImageView android:layout_width="17dp" android:layout_height="17dp" android:src="@drawable/ic_star" app:tint="#E0E0E0" android:layout_marginStart="1dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvTotalReviews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ui_28_anh_gia_kkd3wc"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Right: bar chart -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="@string/auto_ui_5_23_1lbdx9" android:textSize="11sp" android:textColor="#666666"/>
                <ProgressBar android:id="@+id/ovBar5" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="7dp" android:max="100" android:progress="82" android:progressTint="#F5A623"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="@string/auto_ui_4_1_44hy25" android:textSize="11sp" android:textColor="#666666"/>
                <ProgressBar android:id="@+id/ovBar4" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="7dp" android:max="100" android:progress="4" android:progressTint="#F5A623"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="@string/auto_ui_3_2_43y5hn" android:textSize="11sp" android:textColor="#666666"/>
                <ProgressBar android:id="@+id/ovBar3" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="7dp" android:max="100" android:progress="7" android:progressTint="#F5A623"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="@string/auto_ui_2_0_43ecuk" android:textSize="11sp" android:textColor="#666666"/>
                <ProgressBar android:id="@+id/ovBar2" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="7dp" android:max="100" android:progress="0" android:progressTint="#F5A623"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="@string/auto_ui_1_2_42ukax" android:textSize="11sp" android:textColor="#666666"/>
                <ProgressBar android:id="@+id/ovBar1" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="7dp" android:max="100" android:progress="7" android:progressTint="#F5A623"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

    <!-- Filter chips row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical">

        <!-- Có ảnh chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipPhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ui_co_anh_1vaco5"
            app:chipIcon="@drawable/ic_filter"
            app:chipIconVisible="true"
            app:chipIconSize="16dp"
            android:textSize="13sp"
            app:chipBackgroundColor="@color/white"
            app:chipStrokeWidth="1dp"
            app:chipStrokeColor="#EEEEEE"
            app:checkedIconVisible="false"
            android:checkable="true"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Chip.Filter"/>

        <!-- Star filter chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipStar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ui_sao_jjbequ"
            android:textSize="13sp"
            app:chipBackgroundColor="@color/white"
            app:chipStrokeWidth="1dp"
            app:chipStrokeColor="#EEEEEE"
            app:checkedIconVisible="false"
            android:checkable="true"
            style="@style/Widget.MaterialComponents.Chip.Filter"/>

        <!-- Spacer -->
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- Đặt lại button (visible only when filter active) -->
        <TextView
            android:id="@+id/tvReset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ui_at_lai_ydmr96"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#00B5D8"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

    <!-- Reviews list + empty state wrapped in FrameLayout -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Reviews RecyclerView wrapped in NestedScrollView to add a button at bottom -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvReviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp"
                    android:nestedScrollingEnabled="false" />


            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Empty / No Results state -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ui_symbol_2r52"
                android:textSize="48sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ui_khong_co_ket_qua_phu_hop_1bqa46"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ui_khong_tim_thay_anh_gia_theo_bo_loc_a_chon_yy62su"
                android:textSize="13sp"
                android:textColor="#999999"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/btnResetFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_ui_at_lai_bo_loc_kcgzz3"
                android:textColor="@color/white"
                android:background="@drawable/bg_primary_button"
                android:paddingHorizontal="24dp"
                android:paddingVertical="12dp"/>
        </LinearLayout>

    </FrameLayout>

</LinearLayout>

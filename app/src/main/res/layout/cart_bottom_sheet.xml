<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom sheet giỏ hàng — hiện khi user ấn nút + -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:background="#DDDDDD"
        android:backgroundTint="#CCCCCC" />

    <!-- Header: "Giỏ hàng" + "Xóa hết" + "X" -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="Giỏ hàng"
            android:textColor="#111111"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvClearAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xoá hết"
                android:textColor="#FF4444"
                android:textSize="14sp"
                android:paddingEnd="12dp" />

            <TextView
                android:id="@+id/tvClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="✕"
                android:textColor="#888888"
                android:textSize="18sp" />
        </LinearLayout>
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <!-- Danh sách món trong giỏ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCartItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:nestedScrollingEnabled="true" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginTop="4dp" />

    <!-- Footer: icon giỏ + số lượng | Xem đơn hàng + tổng tiền -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical">

        <!-- Trái: icon giỏ hàng + badge số lượng -->
        <FrameLayout
            android:id="@+id/cartIconContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_shopping_cart"
                android:tint="#111111" />

            <TextView
                android:id="@+id/tvCartCount"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|end"
                android:background="@drawable/badge_circle"
                android:gravity="center"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Phải: nút "Xem đơn hàng • 70.000đ" -->
        <Button
            android:id="@+id/btnViewOrder"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:backgroundTint="#FFCC00"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="Xem đơn hàng • 0đ"
            android:textColor="#111111"
            android:textSize="14sp"
            android:textStyle="bold"
            android:stateListAnimator="@null" />
    </RelativeLayout>

</LinearLayout>

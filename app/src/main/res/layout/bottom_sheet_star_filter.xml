<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:background="#E0E0E0"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="0dp"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Chọn số sao"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"/>

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_rounded_gray"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

    <!-- Star options -->
    <LinearLayout
        android:id="@+id/option5Star"
        style="@style/StarOption">
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginEnd="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5  " android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_star" app:tint="#F5A623"/>
        </LinearLayout>
        <ImageView android:id="@+id/check5" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_filter" app:tint="#00B5D8" android:visibility="gone"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

    <LinearLayout
        android:id="@+id/option4Star"
        style="@style/StarOption">
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4  " android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_star" app:tint="#F5A623"/>
        </LinearLayout>
        <ImageView android:id="@+id/check4" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_filter" app:tint="#00B5D8" android:visibility="gone"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

    <LinearLayout
        android:id="@+id/option3Star"
        style="@style/StarOption">
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3  " android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_star" app:tint="#F5A623"/>
        </LinearLayout>
        <ImageView android:id="@+id/check3" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_filter" app:tint="#00B5D8" android:visibility="gone"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

    <LinearLayout
        android:id="@+id/option2Star"
        style="@style/StarOption">
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2  " android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_star" app:tint="#F5A623"/>
        </LinearLayout>
        <ImageView android:id="@+id/check2" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_filter" app:tint="#00B5D8" android:visibility="gone"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

    <LinearLayout
        android:id="@+id/option1Star"
        style="@style/StarOption">
        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1  " android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_star" app:tint="#F5A623"/>
        </LinearLayout>
        <ImageView android:id="@+id/check1" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_filter" app:tint="#00B5D8" android:visibility="gone"/>
    </LinearLayout>

    <!-- Footer: Bỏ lọc button -->
    <Button
        android:id="@+id/btnBoLoc"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Bỏ lọc"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#006064"
        android:background="@drawable/bg_rounded_teal_light"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"/>

</LinearLayout>

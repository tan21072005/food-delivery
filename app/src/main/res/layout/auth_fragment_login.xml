<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/foodgo_surface"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="600dp"
        android:paddingHorizontal="@dimen/foodgo_screen_gutter"
        android:paddingVertical="@dimen/foodgo_space_l">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/foodgoContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/foodgo_surface_container"
            app:cardCornerRadius="@dimen/foodgo_card_radius"
            app:cardElevation="3dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="@dimen/foodgo_content_max_width"
            app:strokeColor="@color/foodgo_outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/foodgo_space_l">

                <TextView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_foodgo_monogram"
                    android:contentDescription="@string/app_name"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/auto_ui_fg_6x4"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/foodgo_space_m"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/title_login"
                    android:textColor="@color/foodgo_text_primary"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/foodgo_space_s"
                    android:gravity="center"
                    android:text="@string/foodgo_login_tagline"
                    android:textColor="@color/foodgo_text_secondary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/foodgo_space_l"
                    android:backgroundTint="@color/foodgo_coral"
                    android:hint="@string/hint_email"
                    android:inputType="textEmailAddress"
                    android:minHeight="@dimen/foodgo_touch_target"
                    android:paddingHorizontal="@dimen/foodgo_space_s"
                    android:singleLine="true"
                    android:textColor="@color/foodgo_text_primary"
                    android:textColorHint="@color/foodgo_text_secondary" />

                <EditText
                    android:id="@+id/edPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/foodgo_space_m"
                    android:backgroundTint="@color/foodgo_coral"
                    android:hint="@string/hint_password"
                    android:inputType="textPassword"
                    android:minHeight="@dimen/foodgo_touch_target"
                    android:paddingHorizontal="@dimen/foodgo_space_s"
                    android:singleLine="true"
                    android:textColor="@color/foodgo_text_primary"
                    android:textColorHint="@color/foodgo_text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/foodgo_space_l"
                    android:minHeight="@dimen/foodgo_touch_target"
                    android:text="@string/btn_login"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:backgroundTint="@color/foodgo_coral"
                    app:cornerRadius="16dp" />

                <LinearLayout
                    android:id="@+id/linearLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/foodgo_space_m"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvForgetpass"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/foodgo_touch_target"
                        android:gravity="center_vertical"
                        android:text="@string/label_forgot_password"
                        android:textColor="@color/foodgo_brick" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tvSignup"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/foodgo_touch_target"
                        android:gravity="center_vertical"
                        android:text="@string/title_signup"
                        android:textColor="@color/foodgo_brick" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/foodgo_space_m"
                    android:gravity="center"
                    android:text="@string/divider_login_with"
                    android:textColor="@color/foodgo_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/foodgo_space_s"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btn_google_login"
                        android:layout_width="@dimen/foodgo_touch_target"
                        android:layout_height="@dimen/foodgo_touch_target"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/cd_icon_google"
                        android:padding="8dp"
                        android:src="@drawable/google" />

                    <com.facebook.login.widget.LoginButton
                        android:id="@+id/login_button"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/foodgo_touch_target"
                        android:layout_marginStart="@dimen/foodgo_space_m" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>

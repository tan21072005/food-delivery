<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/white">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="2dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="@string/restaurant_info_title"
            app:titleTextColor="#1A1A1A"
            app:titleTextAppearance="@style/TextAppearance.AppCompat.Widget.ActionBar.Title" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
    android:fitsSystemWindows="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/ivRestaurantCover"
                android:layout_width="match_parent"
                android:layout_height="176dp"
                android:contentDescription="@string/cd_banner"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_banner" />

            <!-- Restaurant name + address + Đặt xe -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvInfoName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/restaurant_info_loading"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvInfoDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:lineSpacingMultiplier="1.35"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvInfoAddress"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/restaurant_info_no_address"
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:lineSpacingMultiplier="1.4"/>

                    <TextView
                        android:id="@+id/btnDatXe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/restaurant_info_ride_action"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#00B5D8"
                        android:background="@drawable/bg_rounded_teal_light"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="7dp"
                        android:layout_marginStart="12dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvInfoOpenStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#00B14F"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"/>

            <!-- Rating Breakdown -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="20dp"
                android:gravity="center_vertical">

                <!-- Left: big number + stars + count -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="20dp">

                    <TextView
                        android:id="@+id/tvBigRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/restaurant_info_rating_zero"
                        android:textSize="52sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:lineSpacingMultiplier="1.0"/>

                    <LinearLayout
                        android:id="@+id/starRatingBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <!-- Stars filled programmatically -->
                        <ImageView android:id="@+id/star1" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#F5A623"/>
                        <ImageView android:id="@+id/star2" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                        <ImageView android:id="@+id/star3" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                        <ImageView android:id="@+id/star4" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                        <ImageView android:id="@+id/star5" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#E0E0E0" android:layout_marginStart="1dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRatingCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/restaurant_info_review_count_zero"
                        android:textSize="11sp"
                        android:textColor="#00B14F"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Right: bar chart -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 5 stars -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="14dp" android:layout_height="wrap_content" android:text="@string/restaurant_info_star_5" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                        <ImageView android:layout_width="11dp" android:layout_height="11dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginHorizontal="4dp"/>
                        <ProgressBar android:id="@+id/bar5" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:max="100" android:progress="0" android:progressTint="#F5A623" android:layout_marginEnd="6dp"/>
                        <TextView android:id="@+id/tvBar5Count" android:layout_width="28dp" android:layout_height="wrap_content" android:text="@string/restaurant_info_count_zero" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                    </LinearLayout>

                    <!-- 4 stars -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="14dp" android:layout_height="wrap_content" android:text="@string/restaurant_info_star_4" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                        <ImageView android:layout_width="11dp" android:layout_height="11dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginHorizontal="4dp"/>
                        <ProgressBar android:id="@+id/bar4" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:max="100" android:progress="0" android:progressTint="#F5A623" android:layout_marginEnd="6dp"/>
                        <TextView android:id="@+id/tvBar4Count" android:layout_width="28dp" android:layout_height="wrap_content" android:text="@string/restaurant_info_count_zero" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                    </LinearLayout>

                    <!-- 3 stars -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="14dp" android:layout_height="wrap_content" android:text="@string/restaurant_info_star_3" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                        <ImageView android:layout_width="11dp" android:layout_height="11dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginHorizontal="4dp"/>
                        <ProgressBar android:id="@+id/bar3" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:max="100" android:progress="0" android:progressTint="#F5A623" android:layout_marginEnd="6dp"/>
                        <TextView android:id="@+id/tvBar3Count" android:layout_width="28dp" android:layout_height="wrap_content" android:text="@string/restaurant_info_count_zero" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                    </LinearLayout>

                    <!-- 2 stars -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="14dp" android:layout_height="wrap_content" android:text="@string/restaurant_info_star_2" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                        <ImageView android:layout_width="11dp" android:layout_height="11dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginHorizontal="4dp"/>
                        <ProgressBar android:id="@+id/bar2" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:max="100" android:progress="0" android:progressTint="#F5A623" android:layout_marginEnd="6dp"/>
                        <TextView android:id="@+id/tvBar2Count" android:layout_width="28dp" android:layout_height="wrap_content" android:text="@string/restaurant_info_count_zero" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                    </LinearLayout>

                    <!-- 1 star -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="14dp" android:layout_height="wrap_content" android:text="@string/restaurant_info_star_1" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                        <ImageView android:layout_width="11dp" android:layout_height="11dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginHorizontal="4dp"/>
                        <ProgressBar android:id="@+id/bar1" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:max="100" android:progress="0" android:progressTint="#F5A623" android:layout_marginEnd="6dp"/>
                        <TextView android:id="@+id/tvBar1Count" android:layout_width="28dp" android:layout_height="wrap_content" android:text="@string/restaurant_info_count_zero" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

            <!-- Opening Hours section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/restaurant_info_opening_hours_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="13dp">
                <ImageView
                    style="@style/HoursIcon"
                    android:src="@drawable/ic_access_time"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/restaurant_info_no_opening_hours"
                    android:textSize="14sp"
                    android:textColor="#666666"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

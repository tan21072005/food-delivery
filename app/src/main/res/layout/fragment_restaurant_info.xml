<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/white">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="2dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="Thông tin quán"
            app:titleTextColor="#1A1A1A"
            app:titleTextAppearance="@style/TextAppearance.AppCompat.Widget.ActionBar.Title" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
    android:fitsSystemWindows="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Restaurant name + address + Đặt xe -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvInfoName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tiệm Ăn Phanh Phanh"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvInfoAddress"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="90A Văn Hồ 3, Hai Bà Trưng, Hà Nội"
                        android:textSize="13sp"
                        android:textColor="#666666"
                        android:lineSpacingMultiplier="1.4"/>

                    <TextView
                        android:id="@+id/btnDatXe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚗 Đặt xe"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#00B5D8"
                        android:background="@drawable/bg_rounded_teal_light"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="7dp"
                        android:layout_marginStart="12dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"/>

            <!-- Rating Breakdown -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="20dp"
                android:gravity="center_vertical">

                <!-- Left: big number + stars + count -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="20dp">

                    <TextView
                        android:id="@+id/tvBigRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.3"
                        android:textSize="52sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:lineSpacingMultiplier="1.0"/>

                    <LinearLayout
                        android:id="@+id/starRatingBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <!-- Stars filled programmatically -->
                        <ImageView android:id="@+id/star1" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#F5A623"/>
                        <ImageView android:id="@+id/star2" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                        <ImageView android:id="@+id/star3" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                        <ImageView android:id="@+id/star4" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginStart="1dp"/>
                        <ImageView android:id="@+id/star5" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_star" app:tint="#E0E0E0" android:layout_marginStart="1dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRatingCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2646 đánh giá"
                        android:textSize="11sp"
                        android:textColor="#00B14F"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Right: bar chart -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 5 stars -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="14dp" android:layout_height="wrap_content" android:text="5" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                        <ImageView android:layout_width="11dp" android:layout_height="11dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginHorizontal="4dp"/>
                        <ProgressBar android:id="@+id/bar5" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:max="100" android:progress="86" android:progressTint="#F5A623" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="1917" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                    </LinearLayout>

                    <!-- 4 stars -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="14dp" android:layout_height="wrap_content" android:text="4" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                        <ImageView android:layout_width="11dp" android:layout_height="11dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginHorizontal="4dp"/>
                        <ProgressBar android:id="@+id/bar4" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:max="100" android:progress="8" android:progressTint="#F5A623" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="178" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                    </LinearLayout>

                    <!-- 3 stars -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="14dp" android:layout_height="wrap_content" android:text="3" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                        <ImageView android:layout_width="11dp" android:layout_height="11dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginHorizontal="4dp"/>
                        <ProgressBar android:id="@+id/bar3" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:max="100" android:progress="7" android:progressTint="#F5A623" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="152" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                    </LinearLayout>

                    <!-- 2 stars -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="14dp" android:layout_height="wrap_content" android:text="2" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                        <ImageView android:layout_width="11dp" android:layout_height="11dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginHorizontal="4dp"/>
                        <ProgressBar android:id="@+id/bar2" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:max="100" android:progress="5" android:progressTint="#F5A623" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="109" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                    </LinearLayout>

                    <!-- 1 star -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="14dp" android:layout_height="wrap_content" android:text="1" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                        <ImageView android:layout_width="11dp" android:layout_height="11dp" android:src="@drawable/ic_star" app:tint="#F5A623" android:layout_marginHorizontal="4dp"/>
                        <ProgressBar android:id="@+id/bar1" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="6dp" android:max="100" android:progress="12" android:progressTint="#F5A623" android:layout_marginEnd="6dp"/>
                        <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="277" android:textSize="11sp" android:textColor="#666666" android:gravity="end"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

            <!-- Opening Hours section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Giờ hoạt động"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"/>

            <!-- Chủ nhật -->
            <LinearLayout style="@style/HoursRow">
                <ImageView style="@style/HoursIcon" android:src="@drawable/ic_access_time"/>
                <TextView style="@style/HoursDay" android:text="Chủ nhật"/>
                <TextView style="@style/HoursTime" android:text="07:30 - 21:00"/>
            </LinearLayout>

            <!-- Thứ hai -->
            <LinearLayout style="@style/HoursRow">
                <ImageView style="@style/HoursIcon" android:src="@drawable/ic_access_time"/>
                <TextView style="@style/HoursDay" android:text="Thứ hai"/>
                <TextView style="@style/HoursTime" android:text="07:30 - 21:00"/>
            </LinearLayout>

            <!-- Thứ ba -->
            <LinearLayout style="@style/HoursRow">
                <ImageView style="@style/HoursIcon" android:src="@drawable/ic_access_time"/>
                <TextView style="@style/HoursDay" android:text="Thứ ba"/>
                <TextView style="@style/HoursTime" android:text="07:30 - 21:00"/>
            </LinearLayout>

            <!-- Thứ tư -->
            <LinearLayout style="@style/HoursRow">
                <ImageView style="@style/HoursIcon" android:src="@drawable/ic_access_time"/>
                <TextView style="@style/HoursDay" android:text="Thứ tư"/>
                <TextView style="@style/HoursTime" android:text="07:30 - 21:00"/>
            </LinearLayout>

            <!-- Thứ năm -->
            <LinearLayout style="@style/HoursRow">
                <ImageView style="@style/HoursIcon" android:src="@drawable/ic_access_time"/>
                <TextView style="@style/HoursDay" android:text="Thứ năm"/>
                <TextView style="@style/HoursTime" android:text="07:30 - 21:00"/>
            </LinearLayout>

            <!-- Thứ sáu - TODAY highlighted -->
            <LinearLayout
                android:id="@+id/rowToday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="13dp"
                android:background="#FFFDE7">
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_access_time" app:tint="#AAAAAA" android:layout_marginEnd="10dp"/>
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="Thứ sáu" android:textSize="14sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="07:30 - 21:00" android:textSize="14sp" android:textStyle="bold" android:textColor="#1A1A1A"/>
            </LinearLayout>

            <!-- Thứ bảy -->
            <LinearLayout style="@style/HoursRow">
                <ImageView style="@style/HoursIcon" android:src="@drawable/ic_access_time"/>
                <TextView style="@style/HoursDay" android:text="Thứ bảy"/>
                <TextView style="@style/HoursTime" android:text="07:30 - 21:00"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

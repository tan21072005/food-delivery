<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:background="#DDDDDD" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tvCloseTopping"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:text="@string/auto_ui_symbol_c0"
            android:textColor="#888888"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/tvToppingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/auto_ui_chon_mon_mdnxpx"
            android:textColor="#111111"
            android:textSize="17sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/toppingContentScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="20dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/tvNoOptionsMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/auto_ui_mon_nay_chua_co_tuy_chon_them_1pk3th"
                android:textColor="#777777"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/optionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="8dp"
                android:text="@string/auto_ui_ghi_chu_cho_quan_1d8lfa"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etToppingNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_bottom_sheet"
                android:backgroundTint="#F5F5F5"
                android:gravity="top"
                android:hint="@string/auto_ui_ghi_chu_them_khong_bat_buoc_scusmy"
                android:minLines="3"
                android:padding="12dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <LinearLayout
        android:id="@+id/toppingFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvToppingTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/auto_ui_0_6js"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAddToppingCart"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:backgroundTint="#FFCC00"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="@string/auto_ui_them_vao_gio_ndohan"
            android:textColor="#111111"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!-- bottom_sheet_logout.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="#E0E0E0"
        android:layerType="hardware"/>

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingBottom="16dp"
        android:text="@string/auto_ui_ban_co_chac_chan_muon_ang_xuat_12mbjb"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp" />

    <!-- Switch Account Option -->
    <TextView
        android:id="@+id/btnSwitchAccountOption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:text="@string/chuyen_doi_tai_khoan"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_menu_item_ripple"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"/>

    <!-- Logout Option -->
    <TextView
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:text="@string/dang_xuat"
        android:textColor="@color/red_logout"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_menu_item_ripple"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"/>

    <!-- Cancel -->
    <TextView
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:text="@string/huy"
        android:textSize="15sp"
        android:background="@drawable/bg_menu_item_ripple"
        android:clickable="true"
        android:focusable="true"/>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!-- item_profile_header.xml — ViewType: HEADER -->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F5F3FF"
    android:paddingTop="16dp"
    android:paddingBottom="24dp">

    <!-- Mũi tên góc phải -->
    <ImageView
        android:id="@+id/btnMore"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:src="@drawable/ic_arrow_right"
        android:tint="#AAAAAA"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="More" />

    <!-- Avatar -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/imgAvatar"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        app:civ_border_width="3dp"
        app:civ_border_color="@color/white"
        android:src="@drawable/ic_launcher_foreground"
        android:contentDescription="Avatar" />

    <!-- Tên + chevron + edit -->
    <LinearLayout
        android:id="@+id/nameRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/imgAvatar"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trần Nhật Tân"
            android:textColor="#1A1A2E"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnSwitchAccount"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_chevron_down"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Switch account" />

        <ImageView
            android:id="@+id/btnEditProfile"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Edit" />
    </LinearLayout>

    <!-- Badge thành viên -->
    <TextView
        android:id="@+id/tvMemberBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/nameRow"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_badge_member"
        android:text="♦ Thành viên"
        android:textColor="#FFFFFF"
        android:textSize="11sp" />

</RelativeLayout>
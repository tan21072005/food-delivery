<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.FoodDelivery" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/foodgo_coral</item>
        <item name="colorPrimaryVariant">@color/foodgo_brick</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/foodgo_coral</item>
        <item name="colorSecondaryVariant">@color/foodgo_brick</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/foodgo_surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/foodgo_text_secondary</item>
        <item name="colorControlNormal">@color/text_primary</item>
        <!-- Customize your theme here. -->
    </style>
</resources>
